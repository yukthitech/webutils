	<changeSet id="seed-category-and-tag-lovs" author="webutils-testapp">
		<insert tableName="STORED_LOV">
			<column name="NAME" value="CATEGORY"/>
			<column name="DESCRIPTION" value="Sample categories for editable-lov demos"/>
			<column name="AUTH_REQUIRED" valueBoolean="false"/>
		</insert>
		<sql>
			SELECT @categoryLovId:=ID FROM STORED_LOV WHERE NAME = 'CATEGORY';
			INSERT INTO STORED_LOV (NAME, DESCRIPTION, AUTH_REQUIRED, PARENT_LOV_ID)
			VALUES ('TAG', 'Tags under a category for multi-editable-lov', 0, @categoryLovId);
		</sql>
	</changeSet>

	<changeSet id="seed-category-options" author="webutils-testapp">
		<sql>
			SELECT @categoryLovId:=ID FROM STORED_LOV WHERE NAME = 'CATEGORY';
			INSERT INTO STORED_LOV_OPTION (LOV_ID, LABEL, PARENT_OPTION, IS_APPROVED) VALUES
				(@categoryLovId, 'Electronics', 0, 1),
				(@categoryLovId, 'Books', 0, 1),
				(@categoryLovId, 'Clothing', 0, 1),
				(@categoryLovId, 'Home', 0, 1);
		</sql>
	</changeSet>

	<changeSet id="seed-tag-options" author="webutils-testapp">
		<sql>
			SELECT @tagLovId:=ID FROM STORED_LOV WHERE NAME = 'TAG';
			SELECT @electronicsId:=ID FROM STORED_LOV_OPTION WHERE LABEL = 'Electronics' AND LOV_ID = (SELECT ID FROM STORED_LOV WHERE NAME = 'CATEGORY');
			SELECT @booksId:=ID FROM STORED_LOV_OPTION WHERE LABEL = 'Books' AND LOV_ID = (SELECT ID FROM STORED_LOV WHERE NAME = 'CATEGORY');
			SELECT @clothingId:=ID FROM STORED_LOV_OPTION WHERE LABEL = 'Clothing' AND LOV_ID = (SELECT ID FROM STORED_LOV WHERE NAME = 'CATEGORY');
			SELECT @homeId:=ID FROM STORED_LOV_OPTION WHERE LABEL = 'Home' AND LOV_ID = (SELECT ID FROM STORED_LOV WHERE NAME = 'CATEGORY');

			INSERT INTO STORED_LOV_OPTION (LOV_ID, LABEL, PARENT_OPTION, IS_APPROVED) VALUES
				(@tagLovId, 'Phones', @electronicsId, 1),
				(@tagLovId, 'Laptops', @electronicsId, 1),
				(@tagLovId, 'Audio', @electronicsId, 1),
				(@tagLovId, 'Fiction', @booksId, 1),
				(@tagLovId, 'Non-fiction', @booksId, 1),
				(@tagLovId, 'Technical', @booksId, 1),
				(@tagLovId, 'Men', @clothingId, 1),
				(@tagLovId, 'Women', @clothingId, 1),
				(@tagLovId, 'Kids', @clothingId, 1),
				(@tagLovId, 'Kitchen', @homeId, 1),
				(@tagLovId, 'Furniture', @homeId, 1),
				(@tagLovId, 'Decor', @homeId, 1);
		</sql>
	</changeSet>

